{
  "name": "YDB-Qdrant",
  "version": "1.0.0",
  "protocolVersion": "0.3",
  "description": "Qdrant-compatible vector search API on YDB, with hosted Code Indexer MCP for repository memory.",
  "url": "https://ydb-qdrant.tech/",
  "defaultInputModes": [
    "application/json",
    "text/plain"
  ],
  "defaultOutputModes": [
    "application/json",
    "text/markdown"
