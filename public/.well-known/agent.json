    "docs": "https://ydb-qdrant.tech/docs/api/"
  },
  "apis": [
    {
      "type": "openapi",
      "url": "https://ydb-qdrant.tech/openapi.json",
      "docs": "https://ydb-qdrant.tech/docs/api/"
    }
  ],
  "docs": "https://ydb-qdrant.tech/developers/",
  "instructions": "https://ydb-qdrant.tech/docs/agents/",
